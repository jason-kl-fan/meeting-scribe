generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  meetings  Meeting[]

  @@index([createdAt])
}

model Meeting {
  id                 String             @id @default(cuid())
  userId             String
  title              String
  description        String?
  sourceType         MeetingSourceType
  language           String?
  audioUrl           String?
  audioFilename      String?
  audioMimeType      String?
  audioSizeBytes     Int?
  durationSeconds    Int?
  status             MeetingStatus      @default(PENDING)
  errorMessage       String?            @db.Text
  transcriptText     String?            @db.Text
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  speakers           Speaker[]
  transcriptSegments TranscriptSegment[]
  summaries          Summary[]
  actionItems        ActionItem[]
  decisions          Decision[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([sourceType])
}

model Speaker {
  id          String   @id @default(cuid())
  meetingId   String
  speakerKey  String
  displayName String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, speakerKey])
  @@index([meetingId])
}

model TranscriptSegment {
  id         String   @id @default(cuid())
  meetingId  String
  speakerKey String?
  startMs    Int
  endMs      Int
  text       String   @db.Text
  confidence Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, startMs])
  @@index([meetingId, speakerKey])
}

model Summary {
  id            String   @id @default(cuid())
  meetingId     String
  version       Int      @default(1)
  modelName     String?
  promptVersion String?
  summaryText   String   @db.Text
  keyPointsJson Json?
  risksJson     Json?
  nextStepsJson Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  meeting       Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([createdAt])
}

model ActionItem {
  id         String           @id @default(cuid())
  meetingId  String
  assignee   String?
  task       String           @db.Text
  dueDate    DateTime?
  status     ActionItemStatus @default(TODO)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  meeting    Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([status])
}

model Decision {
  id         String   @id @default(cuid())
  meetingId  String
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

enum MeetingStatus {
  PENDING
  UPLOADING
  TRANSCRIBING
  SUMMARIZING
  COMPLETED
  FAILED
}

enum MeetingSourceType {
  RECORDING
  UPLOAD
}

enum ActionItemStatus {
  TODO
  IN_PROGRESS
  DONE
}
